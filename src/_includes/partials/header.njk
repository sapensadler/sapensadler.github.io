<header class="site-header">

  <button class="nav-toggle" aria-controls="main-nav" aria-expanded="false" aria-label="Toggle navigation">
    <span class="hamburger" aria-hidden="true"></span>
  </button>

  <div class="site-title">Japan Karate Association WF England</div>

  <div class="logo-wrap">
    <a class="logo" href="/">
      {% if site.logo %}
        <img src="{{ site.logo }}" alt="{{ site.title }} logo">
      {% else %}
        <img src="/assets/images/logo.svg" alt="{{ site.title }} logo">
      {% endif %}
    </a>
  </div>

  <div class="wrap">
    <nav id="main-nav" class="main-nav" aria-label="Main navigation">
      <ul>
        {% for item in site.nav %}
          <li><a href="{{ item.url }}">{{ item.text }}</a></li>
        {% endfor %}
      </ul>
    </nav>

  </div>
</header>
